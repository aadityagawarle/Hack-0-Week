<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  font-family:"Segoe UI",sans-serif;
  background:#0f0f0f;
  color:#f7f7f7;
}

/* HEADER */
header{
  background:#151515;
  padding:20px 40px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  position:sticky;
  top:0;
  z-index:100;
}

.logo{
  font-size:1.6rem;
  font-weight:bold;
  color:#ffb347;
}

nav a{
  color:#ddd;
  margin-left:20px;
  text-decoration:none;
}
nav a:hover{
  color:#ffb347;
}

/* HERO */
.hero{
  background:url("https://images.unsplash.com/photo-1600891964599-f61ba0e24092?auto=format&fit=crop&w=1600&q=80")
  center/cover no-repeat;
  padding:110px 20px;
  text-align:center;
  position:relative;
}
.hero::before{
  content:"";
  position:absolute;
  inset:0;
  background:rgba(0,0,0,0.75);
}
.hero-content{
  position:relative;
  max-width:700px;
  margin:auto;
}
.hero h1{
  font-size:3rem;
  letter-spacing:3px;
}
.hero p{
  color:#ccc;
  margin-top:10px;
}

/* CATEGORY SLIDER */
.category-slider{
  text-align:center;
  margin:60px auto;
}
.category-slider h2{
  color:#ffb347;
  letter-spacing:2px;
  margin-bottom:25px;
}
.slider{
  display:flex;
  gap:25px;
  overflow-x:auto;
  padding:10px 20px;
}
.slider::-webkit-scrollbar{
  display:none;
}
.category-card{
  min-width:180px;
  background:#1a1a1a;
  border-radius:50%;
  padding:15px;
  cursor:pointer;
  transition:transform .3s;
}
.category-card:hover{
  transform:scale(1.08);
}
.category-card img{
  width:150px;
  height:150px;
  border-radius:50%;
  object-fit:cover;
}
.category-card p{
  margin-top:10px;
  font-size:.9rem;
}

/* MENU SECTIONS */
main{
  max-width:1200px;
  margin:auto;
  padding:40px 20px 80px;
}

.menu-section{
  margin-bottom:60px;
}
.menu-section h2{
  color:#ffb347;
  margin-bottom:10px;
  border-bottom:2px solid #333;
  display:inline-block;
}
.section-subtitle{
  color:#aaa;
  margin-bottom:30px;
}

.menu-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:25px;
}

.menu-item{
  background:#181818;
  border-radius:12px;
  overflow:hidden;
  transition:transform .3s;
}
.menu-item:hover{
  transform:translateY(-6px);
}
.menu-item img{
  width:100%;
  height:190px;
  object-fit:cover;
}
.menu-content{
  padding:15px;
}
.menu-header{
  display:flex;
  justify-content:space-between;
}
.menu-price{
  color:#ffb347;
}
.menu-tag{
  font-size:.75rem;
  color:#999;
  margin:6px 0;
}
.menu-desc{
  font-size:.9rem;
  color:#ccc;
}

/* FOOTER */
footer{
  text-align:center;
  padding:20px;
  border-top:1px solid #222;
  color:#777;
}
</style>
</head>

