<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechFeista Registration</title>
    <style>
        :root {
            --primary-color: #1a2a6c;
            --accent-color: #fdbb2d;
            /* Using a high-quality tech background */
            --bg-image: url('https://images.unsplash.com/photo-1540575861501-7cf05a4b125a?ixlib=rb-4.0.3&auto=format&fit=crop&w=1350&q=80');
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), var(--bg-image);
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }
        .container {
            background: rgba(255, 255, 255, 0.95); 
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
            width: 100%;
            max-width: 500px;
            margin: 20px;
            backdrop-filter: blur(5px);
        }
        h2 {
            text-align: center;
            color: var(--primary-color);
            margin-top: 0;
            font-size: 24px;
        }
        .subtitle {
            text-align: center;
            color: #555;
            margin-bottom: 30px;
            font-weight: 500;
        }
        .form-group {
            margin-bottom: 15px;
        }
        label {
            display: block;
            margin-bottom: 5px;
            font-weight: 600;
            color: #333;
            font-size: 14px;
        }
        input, select {
            width: 100%;
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 8px;
            box-sizing: border-box;
            transition: 0.3s;
        }
        input:focus {
            border-color: var(--primary-color);
            outline: none;
            box-shadow: 0 0 8px rgba(26, 42, 108, 0.3);
        }
        .row {
           display: flex;
            gap: 15px;
        }
        .row .form-group {
            flex: 1;
        }
        button {
            width: 100%;
            padding: 15px;
            background: var(--primary-color);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 10px;
            transition: transform 0.2s, background 0.3s;
        }
        button:hover {
            background: #0d1a4a;
            transform: translateY(-2px);
        }
        @media (max-width: 480px) {
            .row {
                flex-direction: column;
                gap: 0;
            }
        }
    </style>
</head>
<body>
<div class="container">
    <h2>TechFeista Registration</h2>
    <p class="subtitle">Secure your spot for the Tech Fest 2026</p>
    <form id="regForm">
        <div class="form-group">
            <label>Full Name</label>
            <input type="text" placeholder="Aaditya Gawarle" required>
        </div>
        <div class="row">
            <div class="form-group">
                <label>PRN (Roll No)</label>
                <input type="text" placeholder="Roll Number" required>
            </div>
            <div class="form-group">
                <label>Section</label>
                <select required>
                    <option value="">Select</option>
                    <option>A</option>
                    <option>B</option>
                    <option>C</option>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label>Email Address</label>
            <input type="email" placeholder="email@example.com" required>
        </div>

        <div class="row">
            <div class="form-group">
                <label>Semester</label>
                <select required>
                    <option value="">Select</option>
                    <option>1</option><option>2</option><option>3</option><option>4</option>
                    <option>5</option><option>6</option><option>7</option><option>8</option>
                </select>
            </div>
            <div class="form-group">
                <label>Contact No</label>
                <input type="tel" pattern="[0-9]{10}" placeholder="10-digit number" required>
            </div>
        </div>

        <button type="submit">Register Now</button>
    </form>
</div>

<script>
    document.getElementById('regForm').onsubmit = function(e) {
        e.preventDefault();
        alert('Registration Successful!');
    }
</script>

</body>
</html>
