<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Desi Bazaar - Electronics Fixed ✅</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { 
            font-family: 'Arial', sans-serif;
            background: linear-gradient(-45deg, #FF9933, #00CC66, #FF66CC, #FFD700, #3399FF, #FF3333);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            min-height: 100vh;
            padding: 20px;
        }
        @keyframes gradientShift { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
        
        header { background: rgba(255,255,255,0.95); padding: 10px 0; box-shadow: 0 4px 20px rgba(255,153,51,0.5); border-bottom: 5px solid #FFD700; }
        .navbar { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 0 20px; }
        .navbar h2 { color: #FF9933; font-size: 1.8em; text-shadow: 2px 2px 4px #FFD700; }
        .cart-icon { font-size: 1.5em; background: linear-gradient(45deg, #FF9933, #00CC66); color: white; padding: 12px 18px; border-radius: 50px; cursor: pointer; box-shadow: 0 6px 15px rgba(0,204,102,0.4); transition: all 0.4s; animation: bounce 2s infinite; }
        @keyframes bounce { 0%,20%,50%,80%,100% { transform: translateY(0); } 40% { transform: translateY(-10px); } 60% { transform: translateY(-5px); } }
        .cart-icon:hover { background: linear-gradient(45deg, #FF66CC, #3399FF); transform: scale(1.2) rotate(5deg); }
        
        .container { max-width: 1200px; margin: 20px auto; }
        h1 { text-align: center; margin-bottom: 30px; background: linear-gradient(45deg, #FFD700, #FF9933, #00CC66); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; text-shadow: 3px 3px 6px rgba(0,0,0,0.3); font-size: 2.8em; animation: glow 2s ease-in-out infinite alternate; }
        @keyframes glow { from { text-shadow: 3px 3px 6px rgba(0,0,0,0.3), 0 0 20px #FFD700; } to { text-shadow: 3px 3px 6px rgba(0,0,0,0.3), 0 0 30px #FF9933; } }
        
        .product-grid { list-style: none; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px; }
        .product { background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(255,255,255,0.8)); border-radius: 20px; box-shadow: 0 10px 25px rgba(255,153,51,0.4), 0 0 20px rgba(0,204,102,0.3); overflow: hidden; transition: all 0.5s; border: 3px solid transparent; background-clip: padding-box; }
        .product:hover { transform: translateY(-15px) scale(1.05); box-shadow: 0 20px 40px rgba(255,102,204,0.5), 0 0 40px rgba(51,153,255,0.4); border-color: #FFD700; }
        .product-image img { width: 100%; height: 220px; object-fit: cover; transition: transform 0.5s, filter 0.5s; border-radius: 15px 15px 0 0; }
        .product:hover .product-image img { transform: scale(1.2); filter: hue-rotate(180deg) brightness(1.1); }
        .product-info { padding: 25px; text-align: center; }
        .product-info h3 { margin-bottom: 12px; background: linear-gradient(45deg, #333, #FF9933); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-size: 1.4em; }
        .price { font-size: 1.5em; font-weight: bold; background: linear-gradient(45deg, #00CC66, #28a745); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 10px; }
        .category { color: #FF66CC; font-size: 1.1em; font-weight: bold; margin-bottom: 18px; text-shadow: 1px 1px 2px rgba(0,0,0,0.2); }
        .add-to-cart { background: linear-gradient(45deg, #FF9933, #FFD700, #FF66CC); background-size: 300% 300%; animation: buttonGradient 3s ease infinite; color: white; border: none; padding: 15px 30px; border-radius: 30px; font-size: 1.1em; font-weight: bold; cursor: pointer; transition: all 0.4s; box-shadow: 0 6px 15px rgba(255,153,51,0.5); text-transform: uppercase; letter-spacing: 1px; }
        @keyframes buttonGradient { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
        .add-to-cart:hover { background: linear-gradient(45deg, #00CC66, #3399FF, #FF3333); transform: scale(1.1) rotate(2deg); box-shadow: 0 10px 25px rgba(0,204,102,0.6); }
        
        @media (max-width: 768px) { .product-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; } h1 { font-size: 2.2em; } }
    </style>
</head>
<body>
    <header>
        <nav class="navbar">
            <h2>🛍️ Desi Bazaar</h2>
            <div class="cart-icon" onclick="toggleCart()">
                🛒 <span id="cart-count">0</span>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <h1>🌈 Featured Electronics</h1>
        <ul class="product-grid">
            <!-- GAMING LAPTOP - WORKING -->
            <li class="product">
                <div class="product-image">
                    <img src="https://images.unsplash.com/photo-1587829741301-dc798b83defb?w=400&h=220&fit=crop" alt="Gaming Laptop">
                </div>
                <div class="product-info">
                    <h3>Gaming Laptop</h3>
                    <p class="price">₹49,999</p>
                    <p class="category">Electronics</p>
                    <button class="add-to-cart" onclick="addToCart(this)">Add to Cart</button>
                </div>
            </li>
            
            <!-- GAMING MOUSE - WORKING -->
            <li class="product">
                <div class="product-image">
                    <img src="https://images.unsplash.com/photo-1610945262588-8ca3128747e9?w=400&h=220&fit=crop" alt="Gaming Mouse">
                </div>
                <div class="product-info">
                    <h3>Gaming Mouse</h3>
                    <p class="price">₹2,499</p>
                    <p class="category">Electronics</p>
                    <button class="add-to-cart" onclick="addToCart(this)">Add to Cart</button>
                </div>
            </li>
            
            <!-- MECHANICAL KEYBOARD - WORKING -->
            <li class="product">
                <div class="product-image">
                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=400&h=220&fit=crop" alt="Mechanical Keyboard">
                </div>
                <div class="product-info">
                    <h3>Mechanical Keyboard</h3>
                    <p class="price">₹5,999</p>
                    <p class="category">Electronics</p>
                    <button class="add-to-cart" onclick="addToCart(this)">Add to Cart</button>
                </div>
            </li>
            
            <!-- HEADPHONES - WORKING -->
            <li class="product">
                <div class="product-image">
                    <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=400&h=220&fit=crop" alt="Headphones">
                </div>
                <div class="product-info">
                    <h3>Wireless Headphones</h3>
                    <p class="price">₹4,999</p>
                    <p class="category">Electronics</p>
                    <button class="add-to-cart" onclick="addToCart(this)">Add to Cart</button>
                </div>
            </li>
        </ul>
    </div>

    <script>
        let cartCount = 0;
        const cartCountEl = document.getElementById('cart-count');
        function addToCart(button) {
            cartCount++;
            cartCountEl.textContent = cartCount;
            button.textContent = 'Added! ✅';
            button.style.background = '#00CC66';
            setTimeout(() => {
                button.textContent = 'Add to Cart';
                button.style.background = '';
            }, 2000);
        }
        function toggleCart() {
            alert(`You have ${cartCount} items in cart! 🎉`);
        }
    </script>
</body>
</html>
